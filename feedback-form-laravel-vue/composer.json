{
  "name": "groupbuy/feedback-form-laravel-vue",
  "description": "Minimal Laravel backend for feedback form storage factory demo.",
  "type": "project",
  "require": {
    "php": "^7.4|^8.0",
    "laravel/framework": "^8.0|^9.0|^10.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
