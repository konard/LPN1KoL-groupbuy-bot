# ── Shared secret (must be identical in backend and socket) ──────────────────
SECRET_KEY=change-me-to-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=groupbuy

# ── CORS (comma-separated origins allowed in dev/prod) ───────────────────────
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# ── Production domain (used in docker-compose.modular.yml) ───────────────────
DOMAIN=example.com

# ── Service URLs (override for development without Docker) ────────────────────
# BACKEND_URL=http://localhost:8000   # for admin & socket when running locally
# VITE_BACKEND_URL=http://localhost:8000   # for frontend dev server
# VITE_SOCKET_URL=ws://localhost:8001      # for frontend dev server
