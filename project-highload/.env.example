POSTGRES_PASSWORD=groupbuy

PGBOUNCER_MAX_CLIENT_CONN=10000
PGBOUNCER_DEFAULT_POOL_SIZE=80
PGBOUNCER_RESERVE_POOL_SIZE=20

BACKEND_DB_POOL_SIZE=20
BACKEND_DB_MAX_OVERFLOW=40

