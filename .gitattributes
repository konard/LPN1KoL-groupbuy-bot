# Enforce LF line endings for shell scripts and other text files.
# This prevents Windows git clients (with autocrlf=true or eol=crlf) from
# checking out .sh files with CRLF endings, which causes:
#   /bin/bash^M: bad interpreter: No such file or directory
# when the file is mounted into a Linux container.

*.sh        text eol=lf
*.py        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.conf      text eol=lf
*.ini       text eol=lf
*.cfg       text eol=lf
*.toml      text eol=lf
*.env       text eol=lf
*.env.*     text eol=lf
Dockerfile* text eol=lf
Makefile    text eol=lf
