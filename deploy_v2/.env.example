# ── Shared secret (MUST be identical in backend and socket-broker) ────────────
SECRET_KEY=change-me-to-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=groupbuy

# ── CORS (comma-separated origins allowed) ───────────────────────────────────
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# ── Production domain (used for WebSocket URL in frontend build) ─────────────
DOMAIN=localhost

# ── HTTP port exposed by nginx (change on prod if behind another proxy) ──────
# HTTP_PORT=80

# ── Email / SMTP (required for phone-based login OTP delivery) ───────────────
# Without SMTP config the code is printed to backend stdout (development only).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
# How many minutes a login OTP code is valid (default: 10)
LOGIN_CODE_EXPIRE_MINUTES=10
