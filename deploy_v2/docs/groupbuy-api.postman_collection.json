          }
        },
        {
          "name": "Get User Reviews",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/users/{{user_id}}/reviews",
              "host": ["{{base_url}}"],
              "path": ["users", "{{user_id}}", "reviews"]
            },
            "description": "Get all reviews received by this user."
          }
        },
        {
          "name": "Get User Rating",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/users/{{user_id}}/rating",
              "host": ["{{base_url}}"],
              "path": ["users", "{{user_id}}", "rating"]
            },
            "description": "Returns average rating and review count for a user."
          }
        }
      ]
    },
