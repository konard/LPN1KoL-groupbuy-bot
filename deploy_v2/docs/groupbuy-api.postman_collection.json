    {
      "name": "Procurements",
      "item": [
        {
          "name": "List Procurements",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/procurements?status=active&limit=50",
              "host": ["{{base_url}}"],
              "path": ["procurements"],
              "query": [
                {"key": "status", "value": "active", "description": "draft|active|stopped|payment|completed|cancelled"},
                {"key": "city", "value": null, "disabled": true},
                {"key": "category_id", "value": null, "disabled": true},
                {"key": "skip", "value": "0"},
                {"key": "limit", "value": "50"}
              ]
            },
            "description": "List procurements with optional filters."
          }
        },
        {
          "name": "Create Procurement",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/procurements", "host": ["{{base_url}}"], "path": ["procurements"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Group buy iPhone 15\",\n  \"description\": \"Bulk purchase for iPhone 15\",\n  \"category_id\": 1,\n  \"city\": \"Moscow\",\n  \"target_amount\": 10.0,\n  \"unit\": \"units\",\n  \"price_per_unit\": 80000.00,\n  \"commission_percent\": 2.5,\n  \"deadline\": \"2026-06-01T00:00:00Z\"\n}"
