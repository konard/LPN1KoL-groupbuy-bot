              "host": ["{{base_url}}"],
              "path": ["users", "{{user_id}}"]
            },
            "description": "Admin only. Permanently delete user."
          }
        },
        {
          "name": "Get User Balance",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/users/{{user_id}}/balance",
              "host": ["{{base_url}}"],
              "path": ["users", "{{user_id}}", "balance"]
            },
            "description": "Get a user's current balance. Own balance or admin."
          }
        },
        {
          "name": "Adjust User Balance (admin)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/users/{{user_id}}/balance",
              "host": ["{{base_url}}"],
              "path": ["users", "{{user_id}}", "balance"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100.00\n}"
            },
