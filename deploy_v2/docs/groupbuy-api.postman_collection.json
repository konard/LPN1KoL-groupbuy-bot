              "host": ["{{base_url}}"],
              "path": ["procurements", "{{proc_id}}", "toggle-featured"]
            },
            "description": "Admin only. Toggle featured status of a procurement."
          }
        },
        {
          "name": "Search Procurements",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/search/procurements?q=iphone",
              "host": ["{{base_url}}"],
              "path": ["search", "procurements"],
              "query": [{"key": "q", "value": "iphone"}]
            },
            "description": "Full-text search in procurement titles and descriptions."
          }
        }
      ]
    },
