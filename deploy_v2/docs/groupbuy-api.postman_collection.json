{
  "info": {
    "name": "GroupBuy API v2",
    "_postman_id": "groupbuy-api-v2",
    "description": "GroupBuy Backend API v2.0 — group purchasing management platform.\n\n**Auth flow (phone-based)**:\n1. POST /auth/register — create account (username, phone, email, password)\n2. POST /auth/login — provide phone + password → OTP code sent to email\n3. POST /auth/verify-code — provide phone + code → receive Bearer token\n4. Use `Authorization: Bearer {{token}}` on subsequent requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "base_url", "value": "http://localhost:8000", "type": "string"},
    {"key": "token", "value": "", "type": "string"},
    {"key": "phone", "value": "+79991234567", "type": "string"},
    {"key": "user_id", "value": "1", "type": "string"},
    {"key": "proc_id", "value": "1", "type": "string"},
    {"key": "cat_id", "value": "1", "type": "string"},
    {"key": "pay_id", "value": "1", "type": "string"},
    {"key": "room", "value": "general", "type": "string"},
    {"key": "inv_id", "value": "1", "type": "string"},
    {"key": "notif_id", "value": "1", "type": "string"},
    {"key": "complaint_id", "value": "1", "type": "string"},
    {"key": "review_id", "value": "1", "type": "string"}
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"phone\": \"+79991234567\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"SecretPass123\"\n}"
            },
            "description": "Register a new user. Returns user info. Phone and email must be unique."
          }
        },
        {
          "name": "Login (Step 1 — request code)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.email_hint) {",
                  "  pm.collectionVariables.set('phone', pm.request.body.raw ? JSON.parse(pm.request.body.raw).phone : '');",
                  "  console.log('Code sent to', json.email_hint);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"password\": \"SecretPass123\"\n}"
            },
            "description": "Step 1: Send phone + password. A 6-digit OTP code is sent to the user's registered email. Responds with email_hint showing masked email address."
          }
        },
        {
          "name": "Verify Code (Step 2 — get token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('token', json.access_token);",
                  "  console.log('Token saved to collection variable');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/auth/verify-code", "host": ["{{base_url}}"], "path": ["auth", "verify-code"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"code\": \"123456\"\n}"
            },
            "description": "Step 2: Submit phone + 6-digit code received by email. Returns Bearer JWT token. Save token to {{token}} variable."
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"]},
            "description": "Returns the authenticated user's profile."
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/auth/change-password", "host": ["{{base_url}}"], "path": ["auth", "change-password"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"old_password\": \"SecretPass123\",\n  \"new_password\": \"NewPass456\"\n}"
            },
            "description": "Change own password."
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users (admin)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/users?skip=0&limit=50",
              "host": ["{{base_url}}"],
              "path": ["users"],
              "query": [
                {"key": "skip", "value": "0"},
                {"key": "limit", "value": "50"}
              ]
            },
            "description": "Admin only. Returns paginated user list."
          }
        },
        {
          "name": "Search Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/users/search?q=&limit=20",
              "host": ["{{base_url}}"],
              "path": ["users", "search"],
