        {
          "name": "Get Procurement",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/procurements/{{proc_id}}",
              "host": ["{{base_url}}"],
              "path": ["procurements", "{{proc_id}}"]
            },
            "description": "Get procurement details by ID."
          }
        },
        {
          "name": "Update Procurement",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/procurements/{{proc_id}}",
              "host": ["{{base_url}}"],
              "path": ["procurements", "{{proc_id}}"]
