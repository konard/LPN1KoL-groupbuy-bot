{
  "name": "mapsoft/meter-platform",
  "description": "Laravel 9 platform for high-throughput meter readings, billing, notifications, and administration.",
  "type": "project",
  "require": {
    "php": "^8.1",
    "laravel/framework": "^9.0",
    "filament/filament": "^3.0",
    "webmozart/assert": "^1.11",
    "guzzlehttp/guzzle": "^7.8",
    "php-amqplib/php-amqplib": "^3.6",
    "predis/predis": "^2.2"
  },
  "require-dev": {
    "nunomaduro/larastan": "^2.9",
    "phpunit/phpunit": "^9.6",
    "fakerphp/faker": "^1.23"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "test": "phpunit",
    "analyse": "phpstan analyse"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
