# ─── Database ──────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=change_me_in_production
MONOLITH_DB_NAME=monolith_db
CHAT_DB_NAME=chat_db

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Shared by backend-monolith and admin-backend (JWT validation)
JWT_SECRET=change_me_in_production_use_a_long_random_string

# ─── Admin Panel ───────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret

# ─── Centrifugo ────────────────────────────────────────────────────────────────
CENTRIFUGO_API_KEY=centrifugo_api_key

# ─── Gateway ───────────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=60
VOTING_RATE_LIMIT_RPM=120
# Comma-separated origins allowed to call the backend from the browser.
# `*` is accepted for quick local setups but disables `allow_credentials`
# (CORS spec forbids wildcard + credentials together).
# Include user-frontend (3000) and admin-frontend (8080) when developing.
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:8080

# ─── Chat / Media ──────────────────────────────────────────────────────────────
MEDIA_BASE_URL=/api/v1/chat/media

# ─── Notifications ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS=smtp_password
SMTP_FROM=Groupbuy <notifications@example.com>
FCM_SERVER_KEY=your_fcm_server_key

# Optional — leave empty to disable the respective integration
TELEGRAM_BOT_TOKEN=
WHATSAPP_API_URL=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
